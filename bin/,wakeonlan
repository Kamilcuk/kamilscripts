#!/usr/bin/env python3
import argparse
import socket

parser = argparse.ArgumentParser(description="Send Wake-on-LAN magic packet")
parser.add_argument("mac", help="Target MAC address (e.g. AA:BB:CC:DD:EE:FF)")
parser.add_argument("--host", default="255.255.255.255", help="Broadcast address")
parser.add_argument("--port", type=int, default=9)
args = parser.parse_args()

hosts = {"tur": "90:2b:34:31:dd:90"}
mac = hosts.get(args.mac, args.mac) or args.mac

b = bytes.fromhex(mac.replace(":", "").replace("-", ""))
payload = b"\xff" * 6 + b * 16
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
s.sendto(payload, (args.host, args.port))
